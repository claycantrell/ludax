(game "Yavalath" 
    (players 2)
    (equipment 
        (board (hexagon 9))
        (pieces
            ("token" both)
        )
    ) 
    
    (rules 
        (play 
            (repeat (P1 P2)
                (place "token" (destination (empty)))
            )
        )
        (end 
            (if (line "token" 4) (mover win))
            (if (line "token" 3) (mover lose))
        )
    )
)