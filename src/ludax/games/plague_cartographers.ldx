(game "Plague Cartographers"     
    
    (players 2 (set_forward (P1 up) (P2 down)))     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("atlas" both) ("plague" both))     )     
    (rules         
    (start             (place "plague" P1 (0 6 42 48))             (place "plague" P2 (0 6 42 48))         )         
    (play             (repeat (P1 P2)                 (place "atlas" (destination (empty))                     
    (effects                         (capture (custodial "atlas" 1 orientation:orthogonal))                     )                 )             )         )         
    (end             (if (full_board) (by_score))             (if (no_legal_actions) (by_score))         )     ) )