(game "Melt & Purge"     
    
    (players 2)     
    (equipment         (board (rectangle 6 8))         (pieces ("vendor" both)                 ("marker" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "vendor" (destination (empty))                     
    (effects                         (capture (custodial "vendor" 1 orientation:orthogonal))                         (set_score mover (count (occupied mover)))                     )                 )             )         )         
    (end             (if (full_board)                 (by_score)             )         )     ) )