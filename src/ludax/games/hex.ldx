(game "Hex"
    (players 2
        (set_forward (P1 up) (P2 right))
    )
    (equipment 
        (board (hex_rectangle 11 11))
        (pieces
            ("token" both)
        )
    ) 
    
    (rules 
        (play
            (repeat (P1 P2)
                (place "token" (destination empty))
            )
        )
        
        (end
            (if (>= (connected "token" ((edge forward) (edge backward))) 2) (mover win))
        )
    )
)