(game "Vital Networks"     
    
    (players 2)     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("clinic" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "clinic"                     (destination (empty))                     
    (effects                         (flip (custodial "clinic" any))                         (set_score mover (count (occupied mover)))                     )                 )             )         )         
    (end             (if (full_board) (by_score))         )     ) )