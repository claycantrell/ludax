(game "Bitter Roots"     
    
    (players 2 (set_forward (P1 up) (P2 down)))     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("chicory" both)                 ("dormant" both))     )     
    (rules         
    (start             (place "chicory" P1 (0 1 2))             (place "chicory" P2 (46 47 48))         )         
    (play             (repeat (P1 P2)                 (place "chicory" (destination (empty))                     
    (effects                         (capture (custodial "chicory" 1 orientation:orthogonal))                     )                 )             )         )         
    (end             (if (no_legal_actions) (mover lose))             (if (full_board) (by_score))         )     ) )