(game "HopThrough" 
    (players 2
        (set_forward (P1 down) (P2 up))
    )
    (equipment 
        (board (square 8))
        (pieces
            ("token" both)
            ("star" both)
        )
    ) 
    
    (rules
        (start
            (place "star" P1 (row 0))
            (place "token" P1 (row 1))
            (place "token" P2 (row 6))
            (place "star" P2 (row 7))
        )
        (play
            (repeat (P1 P2)
                (or
                    (move "token"
                        (slide direction:forward)
                        (source (occupied mover)) 
                        (destination empty)
                    )
                    (move "star"
                        ((hop direction:forward) (slide direction:orthogonal distance:1))
                        (source (occupied mover)) 
                        (destination empty)
                        (effects (capture (hopped)))
                    )
                )
            )
        )
        
        (end 
            (if (and (exists (and (occupied mover) (row 7))) (mover_is P1)) (mover win))
            (if (and (exists (and (occupied mover) (row 0))) (mover_is P2)) (mover win))
        )
    )
)