(game "Amber Tide"     
    
    (players 2 (set_forward (P1 up) (P2 down)))     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("fish" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "fish" (destination (empty))                     
    (effects                         (capture (custodial "fish" 5 orientation:orthogonal))                     )                 )             )         )         
    (end             (if (line "fish" 5) (mover win))             (if (no_legal_actions) (mover lose))         )     ) )