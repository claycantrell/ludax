(game "Conditional Test"
    (players 2)
    (equipment
        (board (square 7))
    )
    (rules
        (play
            (repeat (P1 P2)
                (place
                    (destination empty)
                    (effects
                        (if (last_move_in (line 3 exact:true))
                            (go_again)
                        )
                    )
                )
            )
        )
        (end
            (if (line 5) (mover win))
            (if (full_board) (draw))
        )
    )
)