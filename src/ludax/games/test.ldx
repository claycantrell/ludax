(game "Test" 
    (players 2)
    (equipment 
        (board (square 15))
        (pieces
            ("token" both)
        )
        (regions
            ("home" (1 2 4))
            ("corners" (corners))
            ("away" (10 20 30))
        )
    ) 
    
    (rules 
        (start
            (place "token" P1 (200 202 204))
            (place "token" P2 (180 182 184))
        )
        (play
            (repeat (P1 P2)
                (move
                    (or
                        (step "token" direction:orthogonal) 
                        (hop "token" direction:orthogonal capture:false)
                    )
                )
            )
        )
        
        (end 
            (if (pattern "token" (2 (0 1 2)) rotate:true) (mover win))
            (if (>= (connected "token" ((region "home") (region "away"))) 2) (mover win))
            (if (full_board) (draw))    
        )
    )
)