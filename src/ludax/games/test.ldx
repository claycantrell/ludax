(game "dhl12l04gqyepux"
    (players 2)
    (equipment
        (board (rectangle 15 10))
        (pieces
            ("token" both)
        )
    )
    (rules
        (play
            (repeat (P1 P2)
                (place "token" (destination (empty)))
            )
        )
        (end
            (if (>= (connected "token" ((edge top) (edge bottom))) 2) (mover win))
        )
    )
)