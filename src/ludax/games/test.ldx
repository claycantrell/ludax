(game "Conditional Test"
    (players 2)
    (equipment
        (board (square 7))
        (pieces
            ("token" both)
            ("special" P1)
        )
    )
    (rules
        (play
            (repeat (P1 P2)
                (place "token"
                    (destination empty)
                    (effects
                        (if (last_move_in (line 3 exact:true))
                            (extra_turn opponent)
                        )
                    )
                )
            )
        )
        (end
            (if (line 3) (mover win))
            (if (full_board) (draw))
        )
    )
)