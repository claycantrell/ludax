(game "Conditional Test"
    (players 2)
    (equipment
        (board (square 7))
        (pieces
            ("token" both)
            ("special" both)
            ("unk" both)
            ("dummy" both)
            ("blorbo" both)
        )
    )
    (rules
        (start
            (place "token" P2 (4))
            (place "special" P1 (8 12 16))
            (place "unk" P2 (40))
            (place "dummy" P1 (6))
            (place "blorbo" P2 (7))
        )
        (play
            (repeat (P1 P2)
                (place "token"
                    (destination empty)
                    (effects
                        (if (last_move_in (line "token" 3 exact:true))
                            (extra_turn opponent)
                        )
                    )
                )
            )
        )
        (end
            (if (line "token" 5) (mover win))
            (if (full_board) (draw))
        )
    )
)