(game "Conditional Test"
    (players 2)
    (equipment
        (board (square 7))
    )
    (rules
        (play
            (repeat (P1 P2)
                (place
                    (destination empty)
                    (effects
                        (if (line 2) (capture (custodial 2) increment_score:true))
                    )
                )
            )
        )
        (end
            (if (line 4) (mover win))
            (if (full_board) (draw))
        )
    )
)