(game "Tic-Tac-Toe" 
    (players 2)
    (equipment 
        (board (square 3))
        (pieces
            ("token" both)
        )
    ) 
    
    (rules 
        (play
            (repeat (P1 P2)
                (place "token" (destination empty))
            )
        )
        
        (end 
            (if (line "token" 3) (mover win))
            (if (full_board) (draw))    
        )
    )
)