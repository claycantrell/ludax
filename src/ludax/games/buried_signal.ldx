(game "Buried Signal"     
    
    (players 2)     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("relay" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "relay"                     (destination (empty))                     
    (effects                         (if                             (exists (and (occupied mover) (adjacent (occupied opponent) direction:orthogonal)))                             (extra_turn mover same_piece:true)                         )                     )                 )             )         )         
    (end             (if (full_board) (by_score))         )     ) )