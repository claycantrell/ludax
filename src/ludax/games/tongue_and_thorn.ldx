(game "Tongue & Thorn"     
    
    (players 2)     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("phrase" both))         (regions             ("center" (24 25 31 32 33 38 39 40))             ("edge_zone" (0 1 2 3 4 5 6 7 13 14 20 21 27 28 34 35 41 42 43 44 45 46 47 48))         )     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "phrase"                     (destination (empty))                     
    (effects                         (set_score mover                             (add                                 (count (occupied mover))                                 (add                                     (multiply 2 (count (and (occupied mover) (region "center"))))                                     (count (and (occupied mover) (region "edge_zone")))                                 )                             )                         )                         (set_score opponent                             (add                                 (count (occupied opponent))                                 (add                                     (multiply 2 (count (and (occupied opponent) (region "center"))))                                     (count (and (occupied opponent) (region "edge_zone")))                                 )                             )                         )                     )                 )             )         )         
    (end             (if (full_board) (by_score))         )     ) )