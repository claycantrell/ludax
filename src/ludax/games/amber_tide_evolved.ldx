(game "Amber Tide"     
    
    (players 2 (set_forward (P1 up) (P2 down)))     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("fish" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "fish" (destination (empty))                     
    (effects (flip (custodial "fish" 3 orientation:orthogonal)) (set_score mover (count (occupied mover))) (set_score opponent (count (occupied opponent))))                 )             )         )         
    (end             (if (>= (connected "fish" ((edge left) (edge right))) 2) (mover win))             (if (full_board) (by_score))         )     ) )