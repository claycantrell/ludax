(game "Ember Syndicate"     
    
    (players 2)     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("conduit" both)                 ("flare" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "conduit" (destination (empty))                     
    (effects                         (capture (custodial "conduit" 1 orientation:orthogonal))                         (set_score mover (count (occupied mover)))                     )                 )             )         )         
    (end             (if (full_board) (by_score))             (if (no_legal_actions) (mover lose))         )     ) )