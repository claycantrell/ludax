(game "Wellspring Commons"     
    
    (players 2)     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("well" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "well"                     (destination (empty))                     
    (effects                         (flip (custodial "well" 1 orientation:orthogonal))                         (increment_score mover (count (custodial "well" 1 orientation:orthogonal)))                     )                 )             )         )         
    (end             (if (>= (score mover) 12) (mover win))             (if (line "well" 4) (mover win))             (if (full_board) (by_score))         )     ) )