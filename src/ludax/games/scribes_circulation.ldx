(game "Scribe's Circulation"     
    
    (players 2)     
    (equipment         (board (hex_rectangle 7 7))         (pieces ("platelet" both))     )     
    (rules         
    (play             (repeat (P1 P2)                 (place "platelet"                     (destination (empty))                     
    (effects                         (capture (custodial "platelet" 1 orientation:any))                         (set_score mover (count (occupied mover)))                         (set_score opponent (count (occupied opponent)))                     )                 )             )         )         
    (end             (if (full_board) (by_score))         )     ) )