(game "Connect-Six"
    (players 2)
    (equipment 
        (board (square 19))
        (pieces 
            ("token" both)
        )
    ) 
    
    (rules 
        (play
            (once_through (P1)
                (place "token" (destination (empty)))
            )
            (repeat (P2 P2 P1 P1)
                (place "token" (destination (empty)))
            )
        )
        (end 
            (if (line "token" 6) (mover win))
        )
    )
)