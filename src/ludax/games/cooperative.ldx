(game "Cooperative-Game"
    (players 2)
    (equipment 
        (board (square 5))
    ) 
    
    (rules 
        (play
            (repeat (P1 P2)
                (place (destination empty))
            )
        )
        
        (end 
            (if (and (line 5 orientation:vertical player:P1) (line 4 orientation:horizontal player:P2)) (both win))
            (if (full_board) (both lose))    
        )
    )
)